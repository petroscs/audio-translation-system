# Environment Variables Template
# Copy this file to .env and update with your values

# Server Configuration
SERVER_IP=192.168.1.100

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_ISSUER=audio-translation-system
JWT_AUDIENCE=audio-translation-clients

# API Configuration (URLs as seen by the browser / other devices)
# For same-machine demo: use localhost. For LAN demo: use this PC's IP (e.g. http://192.168.1.100:5000)
API_URL=http://localhost:5000
LISTENER_URL=http://localhost:3001

# Whisper Model Configuration
# Options: tiny, base, small, medium, large
WHISPER_MODEL=base

# Database Configuration (SQLite - file path)
# For Docker: /data/audio_translation.db
# For local: ./data/audio_translation.db
